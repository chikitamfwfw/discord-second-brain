# ── Vault（ローカルの second-brain リポジトリ） ──────────────────────────
# 未設定なら本リポジトリと同階層の ../second-brain を使用
# VAULT_PATH=/path/to/second-brain
# VAULT_GIT_BRANCH=main

# ── Anthropic（拡張機能/API モードの会話で使用。Claude Code モードでは不要） ──
ANTHROPIC_API_KEY=

# ── Tavily Web 検索（拡張機能モード、任意。未設定なら DuckDuckGo にフォールバック） ──
TAVILY_API_KEY=

# ── GitHub（タスク管理 = Issues / Projects v2 のみで使用） ────────────────
GITHUB_TOKEN=
GITHUB_REPO=username/second-brain

# ── 常駐エンジン（デーモン） ──────────────────────────────────────────────
# BRAIN_DAEMON_HOST=127.0.0.1
# BRAIN_DAEMON_PORT=8765

# ── ChromaDB ──────────────────────────────────────────────────────────────
# CHROMA_DB_PATH=./chroma_db

# ── バックグラウンド同期間隔（秒）。0 で無効 ──────────────────────────────
# SYNC_INTERVAL_SECONDS=600

# ── 会員限定記事用 Cookie（任意） ─────────────────────────────────────────
# ブラウザ拡張「Get cookies.txt LOCALLY」等で Netscape 形式でエクスポート
# COOKIES_FILE=./cookies.txt
